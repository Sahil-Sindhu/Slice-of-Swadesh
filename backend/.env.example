# Server Settings
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/swadesh?retryWrites=true&w=majority

# Security & Sessions
JWT_SECRET=replace_with_a_secure_long_random_string_here
JWT_EXPIRES_IN=1d

# Media Store (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Dispatcher (Nodemailer)
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587
NODEMAILER_USER=your_nodemailer_user_email@gmail.com
NODEMAILER_PASS=your_nodemailer_app_password

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
