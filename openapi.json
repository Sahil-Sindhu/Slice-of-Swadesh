{
  "openapi": "3.0.0",
  "info": {
    "title": "Slice of Swadesh Developer API",
    "version": "1.0.0",
    "description": "API-first specifications for checkout, menu updates, and developer integrations."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate developer or client credentials",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication token successfully generated"
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Submit order payload",
        "security": [
          { "ApiKeyAuth": [] }
        ],
        "responses": {
          "201": {
            "description": "Order processed successfully"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  }
}
